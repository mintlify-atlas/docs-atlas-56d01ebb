  "keyFeatures": [
    "Schema Vault with versioned, hash-verified schemas",
    "Integrity Modes for runtime governance (readonly/standard/privileged/emergency)",
    "Type-safe schema DSL with compile-time validation",
    "Query builder with field projection and eager loading",
    "Automatic schema migrations with PostgreSQL backend",
    "Database introspection (DB to schema generation)",
    "IdentityMap for automatic object deduplication",
    "Complete audit trail with append-only integrity log"
  ],
  "publicApiSurface": [
    "chameleon init - Initialize project with Schema Vault",
    "chameleon migrate - Generate and apply schema migrations",
    "chameleon validate - Validate schema syntax and semantics",
    "chameleon verify - Verify vault integrity with SHA256 hashing",
    "chameleon status - Show vault and mode status",
    "chameleon journal schema - View schema version history",
    "chameleon config - Manage integrity modes and settings",
    "chameleon introspect - Generate schema from existing database",
    "engine.NewEngine() - Initialize database connection with vault",
    "Query(entity) - Build and execute type-safe queries",
    "Insert(entity) - Insert records with validation",
    "Update(entity) - Update records with safety guards",
    "Delete(entity) - Delete records with WHERE clause requirement",
    "Filter(field, op, value) - Add filter conditions to queries",
    "Include(relation) - Eager load related entities",
    "Select(fields...) - Project specific fields",
    "Debug() - Enable SQL query visibility"
  ]
}
